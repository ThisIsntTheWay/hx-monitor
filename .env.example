# Example environment variables for hx-monitor services

# DB config
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=password
MONGODB_AUTH_DATABASE=admin
MONGODB_DATABASE=hx

# api-backend configuration
LISTEN_PORT=8080

# frontend configuration
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_AIRSPACES_JSON_URL=https://airspace.shv-fsvl.ch/api/v1/geojson/airspaces
REACT_APP_PRE_FILTER_GEO_JSON=true

# Callback configuration - set only one of the NGROK or Twilio values
NGROK_AUTHTOKEN=
TWILIO_API_CALLBACK_URL=

# Twilio settings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_CALL_FROM=
TWILIO_CALL_LENGTH=38

# Additional third-party keys
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
